{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "types": ["vitest/globals", "node"],
    
    "paths": {
      "@/*": ["./*"],
      "@/app/*": ["app/*"],
      "@/components/*": ["app/components/*"],
      "@/lib/*": ["lib/*"],
      "@/hooks/*": ["app/hooks/*"],
      "@/contexts/*": ["app/contexts/*"],
      "@/lib/firebase/*": ["firebase/*"],
      "@/utils/*": ["utils/*"]
    },

    "plugins": [{ "name": "next" }],

  
  },
 
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],

  "exclude": ["node_modules"]
}